---
const { roles = ['researcher', 'writer', 'data scientist', 'curious human'], interval = 2500 } = Astro.props;
---
<div class="role-line">
  I'm a <span class="role-loop" data-roles={JSON.stringify(roles)} data-interval={interval}>{roles[0]}</span>
</div>

<style>
  .role-line {
    font-family: var(--font-serif);
    font-weight: 300;
    font-style: italic;
    font-size: 1.6rem;
    color: var(--ink-soft);
    min-height: 2.4rem;
  }
  .role-loop {
    display: inline-block;
    color: var(--teal);
    font-style: normal;
    font-weight: 500;
    transition: opacity 0.4s ease;
  }
  .role-loop::after {
    content: '|';
    margin-left: 4px;
    color: var(--peach);
    font-weight: 300;
    animation: blink 1s steps(2) infinite;
  }
  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }
  @media (max-width: 720px) {
    .role-line { font-size: 1.3rem; }
  }
</style>

<script>
  document.querySelectorAll('.role-loop').forEach((el) => {
    const target = el as HTMLElement;
    const roles = JSON.parse(target.dataset.roles || '[]') as string[];
    const interval = parseInt(target.dataset.interval || '2500', 10);
    if (roles.length < 2) return;
    let idx = 0;
    setInterval(() => {
      idx = (idx + 1) % roles.length;
      target.style.opacity = '0';
      setTimeout(() => {
        target.textContent = roles[idx];
        target.style.opacity = '1';
      }, 400);
    }, interval);
  });
</script>
