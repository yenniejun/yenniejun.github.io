---
const { book } = Astro.props;
const url = book.data.path;
const date = book.data.date instanceof Date ? book.data.date : new Date(book.data.date);
const dateStr = date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
const tags = book.data.tags || [];
---
<a class="book-item" href={url} data-tags={JSON.stringify(tags)}>
  <span class="date">{dateStr}</span>
  <div class="content">
    <h3>{book.data.title}</h3>
    <div class="meta">
      {book.data.author && <span class="author">by {book.data.author}</span>}
      {book.data.rating && <span class="rating">★ {book.data.rating}</span>}
    </div>
    {book.data.description && <p class="desc">{book.data.description}</p>}
    {tags.length > 0 && (
      <div class="book-tags">{tags.join(' · ')}</div>
    )}
  </div>
</a>

<style>
  .book-item {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--rule);
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s ease;
  }
  .book-item:hover {
    transform: translateX(6px);
  }
  .book-item:hover h3 { color: var(--teal); }
  .date {
    font-family: var(--font-soft);
    font-size: 0.85rem;
    color: var(--ink-soft);
    padding-top: 0.4rem;
    letter-spacing: 0.02em;
  }
  .content h3 {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 1.3rem;
    margin: 0 0 0.4rem;
    letter-spacing: -0.01em;
    transition: color 0.25s ease;
  }
  .meta {
    display: flex;
    gap: 0.85rem;
    align-items: center;
    margin-bottom: 0.6rem;
    flex-wrap: wrap;
  }
  .author {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--ink-soft);
    font-size: 0.95rem;
  }
  .rating {
    color: var(--peach);
    font-size: 0.85rem;
    font-weight: 600;
    font-family: var(--font-soft);
  }
  .desc {
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.95rem;
    line-height: 1.5;
    font-family: var(--font-soft);
  }
  .book-tags {
    font-family: var(--font-soft);
    font-size: 0.78rem;
    color: var(--ink-faint);
    margin-top: 0.6rem;
    letter-spacing: 0.01em;
    font-weight: 500;
  }
  @media (max-width: 720px) {
    .book-item {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
  }
</style>
