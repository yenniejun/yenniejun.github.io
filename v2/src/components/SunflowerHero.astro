<div class="flower-box">
  <svg class="sunflower" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <!-- Petals: rotate clockwise (40s) -->
    <g class="petals">
      <ellipse cx="50" cy="20" rx="8" ry="18" fill="#f5b89a" />
      <ellipse cx="50" cy="20" rx="8" ry="18" fill="#f5b89a" transform="rotate(30 50 50)" />
      <ellipse cx="50" cy="20" rx="8" ry="18" fill="#f5b89a" transform="rotate(60 50 50)" />
      <ellipse cx="50" cy="20" rx="8" ry="18" fill="#f5b89a" transform="rotate(90 50 50)" />
      <ellipse cx="50" cy="20" rx="8" ry="18" fill="#f5b89a" transform="rotate(120 50 50)" />
      <ellipse cx="50" cy="20" rx="8" ry="18" fill="#f5b89a" transform="rotate(150 50 50)" />
      <ellipse cx="50" cy="20" rx="8" ry="18" fill="#f5b89a" transform="rotate(180 50 50)" />
      <ellipse cx="50" cy="20" rx="8" ry="18" fill="#f5b89a" transform="rotate(210 50 50)" />
      <ellipse cx="50" cy="20" rx="8" ry="18" fill="#f5b89a" transform="rotate(240 50 50)" />
      <ellipse cx="50" cy="20" rx="8" ry="18" fill="#f5b89a" transform="rotate(270 50 50)" />
      <ellipse cx="50" cy="20" rx="8" ry="18" fill="#f5b89a" transform="rotate(300 50 50)" />
      <ellipse cx="50" cy="20" rx="8" ry="18" fill="#f5b89a" transform="rotate(330 50 50)" />
    </g>

    <!-- Center disc + seeds: rotate counter-clockwise (60s) -->
    <g class="center">
      <circle cx="50" cy="50" r="14" fill="#09646A" />
      <g class="seeds">
        <circle class="seed seed-1" cx="46" cy="46" r="1.5" fill="#84BAB8" />
        <circle class="seed seed-2" cx="54" cy="47" r="1.5" fill="#84BAB8" />
        <circle class="seed seed-3" cx="50" cy="53" r="1.5" fill="#84BAB8" />
        <circle class="seed seed-4" cx="45" cy="54" r="1.5" fill="#84BAB8" />
        <circle class="seed seed-5" cx="55" cy="55" r="1.5" fill="#84BAB8" />
        <circle class="seed seed-6" cx="49" cy="48" r="1.2" fill="#84BAB8" />
        <circle class="seed seed-7" cx="52" cy="51" r="1.2" fill="#84BAB8" />
      </g>
    </g>
  </svg>
</div>

<style>
  .flower-box {
    width: 280px;
    height: 280px;
    background: var(--peach-soft);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    /* whole vase gently breathes */
    animation: vase-breathe 9s ease-in-out infinite;
  }
  @keyframes vase-breathe {
    0%, 100% { scale: 1; }
    50%      { scale: 1.018; }
  }

  /* Halo layer 1 — peach blobs, STATIC position. Only breathes (opacity + scale). */
  .flower-box::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: conic-gradient(
      from 0deg,
      transparent 0%,
      rgba(245, 184, 154, 0.42) 16%,
      transparent 33%,
      transparent 66%,
      rgba(245, 184, 154, 0.38) 83%,
      transparent 100%
    );
    z-index: 0;
    pointer-events: none;
    animation: halo-breathe 7s ease-in-out infinite;
  }
  @keyframes halo-breathe {
    0%, 100% { opacity: 0.55; scale: 1; }
    50%      { opacity: 1;    scale: 1.05; }
  }

  /* Halo layer 2 — single teal blob, slowly orbits (opposite direction of
     petals), letting the green "wander" through the halo. */
  .flower-box::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: conic-gradient(
      from 0deg,
      transparent 35%,
      rgba(132, 186, 184, 0.36) 50%,
      transparent 65%,
      transparent 100%
    );
    z-index: 0;
    pointer-events: none;
    animation: teal-orbit 35s linear infinite;
  }
  @keyframes teal-orbit {
    from { rotate: 0deg; }
    to   { rotate: -360deg; }
  }

  .sunflower {
    width: 70%;
    position: relative;
    z-index: 1;
    overflow: visible;
  }

  /* Petals: rotate clockwise + scale-breathe.
     Rotation uses non-uniform keyframes + per-segment easing so the petals
     accelerate, slow down, nearly pause, then accelerate again — about 2
     breath cycles per full turn. Boundary stops at "slow" on both ends so
     the loop is seamless (no jump when 100% wraps to 0%). */
  .petals {
    transform-box: fill-box;
    transform-origin: 50% 50%;
    animation:
      spin-cw 50s linear infinite,
      petals-breathe 6s ease-in-out infinite;
  }
  /* Non-uniform stops with linear interpolation = different constant speeds
     per segment. No ease-in/out, so the minimum velocity stays well above
     zero (~5 deg/s) while the max bursts up to ~11 deg/s. */
  @keyframes spin-cw {
    0%   { rotate: 0deg;   }   /* segment avg 5.3 deg/s */
    30%  { rotate: 80deg;  }   /* segment avg 11.2 deg/s */
    55%  { rotate: 220deg; }   /* segment avg 6.0 deg/s */
    80%  { rotate: 295deg; }   /* segment avg 6.5 deg/s */
    100% { rotate: 360deg; }
  }
  @keyframes petals-breathe {
    0%, 100% { scale: 1; }
    50%      { scale: 1.05; }
  }

  /* Center disc + seeds: counter-clockwise + subtle pulse */
  .center {
    transform-box: fill-box;
    transform-origin: 50% 50%;
    animation:
      spin-ccw 60s linear infinite,
      center-pulse 4.5s ease-in-out infinite;
  }
  @keyframes spin-ccw {
    from { rotate: 0deg; }
    to   { rotate: -360deg; }
  }
  @keyframes center-pulse {
    0%, 100% { scale: 1; }
    50%      { scale: 1.07; }
  }

  /* Seeds: twinkle (opacity + scale) + tiny positional drift on top */
  .seed {
    transform-box: fill-box;
    transform-origin: 50% 50%;
    animation:
      twinkle 3.4s ease-in-out infinite,
      seed-drift 7s ease-in-out infinite;
  }
  .seed-1 { animation-delay: 0s,    0s;   animation-duration: 3.4s, 6.2s; }
  .seed-2 { animation-delay: 0.5s,  1.1s; animation-duration: 4.1s, 7.5s; }
  .seed-3 { animation-delay: 1.1s,  2.4s; animation-duration: 3.7s, 6.8s; }
  .seed-4 { animation-delay: 1.6s,  0.6s; animation-duration: 4.3s, 8.1s; }
  .seed-5 { animation-delay: 2.2s,  1.8s; animation-duration: 3.9s, 7.0s; }
  .seed-6 { animation-delay: 0.8s,  3.0s; animation-duration: 4.6s, 6.5s; }
  .seed-7 { animation-delay: 1.9s,  0.2s; animation-duration: 3.2s, 7.8s; }

  @keyframes twinkle {
    0%, 100% { opacity: 0.3; scale: 0.85; }
    50%      { opacity: 1;   scale: 1.3; }
  }
  @keyframes seed-drift {
    0%, 100% { translate: 0 0; }
    25%      { translate: 0.4px -0.3px; }
    50%      { translate: 0 0.4px; }
    75%      { translate: -0.4px -0.2px; }
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .flower-box,
    .petals, .center, .seed,
    .flower-box::before,
    .flower-box::after {
      animation: none !important;
    }
  }

  @media (max-width: 720px) {
    .flower-box {
      width: 180px;
      height: 180px;
      margin: 0 auto;
    }
  }
</style>
