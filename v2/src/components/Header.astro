---
const { current = "/" } = Astro.props;
const links = [
  { href: "/projects", label: "Projects" },
  { href: "/writing",  label: "Writing"  },
  { href: "/books",    label: "Books"    },
];
---
<nav class="site-nav">
  <div class="nav-inner">
    <a href="/" class="brand" aria-label="Home">
      <img src="/sunflower-bold.svg" alt="" />
      <span>yennie jun</span>
    </a>

    <div class="links">
      {links.map(link => (
        <a href={link.href} class:list={[{ active: current === link.href }]}>{link.label}</a>
      ))}
      <a href="https://www.artfish.ai/" target="_blank" rel="noreferrer">Newsletter <span class="arrow">↗</span></a>
    </div>
  </div>
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(250, 246, 240, 0.88);
    backdrop-filter: blur(14px) saturate(180%);
    -webkit-backdrop-filter: blur(14px) saturate(180%);
    border-bottom: 1px solid var(--rule);
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }
  .site-nav.scrolled {
    background: rgba(250, 246, 240, 0.95);
    box-shadow: 0 4px 24px -16px rgba(0,0,0,0.12);
  }
  .nav-inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0.9rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 1.05rem;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: -0.01em;
    display: flex;
    align-items: center;
    gap: 0.55rem;
    transition: opacity 0.2s ease;
  }
  .brand:hover { opacity: 0.7; }
  .brand img {
    width: 1.6rem;
    height: 1.6rem;
  }

  .links {
    display: flex;
    gap: 1.6rem;
    font-size: 0.95rem;
    font-family: var(--font-sans);
  }
  .links a {
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.2s ease;
    position: relative;
  }
  .links a:hover { color: var(--teal); }
  .links a.active {
    color: var(--ink);
    font-weight: 500;
  }
  .links a.active::after {
    content: '';
    position: absolute;
    left: 0; right: 0;
    bottom: -6px;
    height: 2px;
    background: var(--peach);
    border-radius: 2px;
  }
  .links .arrow {
    font-size: 0.85em;
    opacity: 0.7;
  }

  @media (max-width: 720px) {
    .nav-inner { padding: 0.75rem 1.25rem; }
    .brand span { display: none; }
    .links { gap: 1rem; font-size: 0.85rem; }
  }
</style>

<script>
  const nav = document.querySelector('.site-nav');
  if (nav) {
    const onScroll = () => nav.classList.toggle('scrolled', window.scrollY > 16);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
