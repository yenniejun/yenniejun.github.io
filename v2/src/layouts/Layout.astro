---
import '../styles/global.css';

const { title = "Yennie Jun", description = "Yennie Jun's personal website" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/sunflower-bold.svg" />
</head>
<body>
  <slot />

  <script is:inline>
    /* threshold low so very-tall articles (whose max intersection ratio
       is itself small) still trigger the fade-in */
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) entry.target.classList.add('in');
      });
    }, { threshold: 0.01 });
    document.querySelectorAll('.fade-up').forEach((el, i) => {
      el.style.transitionDelay = (i * 0.06) + 's';
      observer.observe(el);
    });
  </script>
</body>
</html>
