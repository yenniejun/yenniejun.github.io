---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/PageHeader.astro';
import projects from '../data/portfolio.json';

const allTags: string[] = [...new Set(projects.flatMap((p: any) => p.tags || []))]
  .sort((a: string, b: string) => a.localeCompare(b));
---
<Layout title="Projects — Yennie Jun">
  <Header current="/projects" />
  <main>
    <PageHeader title="Projects" icon="projects">
      <p>My more recent writing and projects can be found on <a href="https://www.artfish.ai/" target="_blank" rel="noreferrer">Art Fish Intelligence</a> ↗</p>
    </PageHeader>

    {/* ====================================================================
        TAG FILTER — commented out for now. To re-enable:
          1. Uncomment this block
          2. Uncomment the <script is:inline> block lower in this file
        The `allTags` variable, the `data-tags` attribute on each project,
        and the `.filter-bar`/`.filter-pill` CSS are all left in place.
    ==================================================================== */}
    {/*
    <div class="filter-bar fade-up" id="filter-bar">
      <button class="filter-pill active" data-filter="all">
        All <span class="count">{projects.length}</span>
      </button>
      {allTags.map(tag => {
        const count = projects.filter((p: any) => p.tags?.includes(tag)).length;
        return (
          <button class="filter-pill" data-filter={tag}>
            {tag} <span class="count">{count}</span>
          </button>
        );
      })}
    </div>
    */}

    <div class="projects" id="projects-list">
      {projects.map((project: any) => (
        <article class="project fade-up" data-tags={JSON.stringify(project.tags || [])}>
          {project.image && (
            <div class="project-img-wrap">
              <img src={`/projects/${project.image}`} alt="" class="project-img" loading="lazy" />
            </div>
          )}
          <div class="project-body">
            <h2>{project.title}</h2>
            {project.description?.map((d: string) => <p>{d}</p>)}
            {project.announcement && <p class="announcement">{project.announcement}</p>}
            {project.tags && (
              <div class="tags">
                {project.tags.map((t: string) => <span class="tag">{t}</span>)}
              </div>
            )}
            <div class="links">
              {project.articlelink && <a href={project.articlelink} target="_blank" rel="noreferrer">Article ↗</a>}
              {project.paperlink && <a href={project.paperlink} target="_blank" rel="noreferrer">Paper ↗</a>}
              {project.codelink && <a href={project.codelink} target="_blank" rel="noreferrer">Code ↗</a>}
              {project.demolink && <a href={project.demolink} target="_blank" rel="noreferrer">Demo ↗</a>}
              {project.instagramlink && <a href={project.instagramlink} target="_blank" rel="noreferrer">Instagram ↗</a>}
            </div>
          </div>
        </article>
      ))}
      <p class="no-results" id="no-results" hidden>No projects with that tag.</p>
    </div>

    <Footer />
  </main>
</Layout>

{/* ====================================================================
    TAG FILTER SCRIPT — commented out. Uncomment together with the
    filter-bar block above to re-enable filtering.
==================================================================== */}
