<style>
  /* ---------- Filter bar ---------- */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 2rem 0 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--rule);
  }
  .filter-pill {
    font-family: var(--font-soft);
    font-size: 0.85rem;
    padding: 0.4rem 0.85rem;
    border-radius: 100px;
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--ink-soft);
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    line-height: 1;
  }
  .filter-pill:hover {
    border-color: var(--teal);
    color: var(--ink);
  }
  .filter-pill.active {
    background: var(--ink);
    color: var(--bg);
    border-color: var(--ink);
  }
  .filter-pill .count {
    font-size: 0.72rem;
    opacity: 0.65;
    font-weight: 400;
  }

  /* ---------- Projects ---------- */
  .projects {
    display: flex;
    flex-direction: column;
    gap: 4rem;
    margin-top: 1rem;
  }
  .project {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 2.5rem;
    align-items: start;
    transition: opacity 0.3s ease;
  }
  .project.hide {
    display: none;
  }

  .project-img-wrap {
    border-radius: 14px;
    overflow: hidden;
    background: var(--peach-soft);
  }
  .project-img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.5s ease;
  }
  .project:hover .project-img {
    transform: scale(1.04);
  }
  .project-body h2 {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 1.65rem;
    margin: 0 0 0.85rem;
    letter-spacing: -0.02em;
    color: var(--ink);
    line-height: 1.2;
  }
  .project-body p {
    margin: 0 0 1rem;
    color: var(--ink-soft);
    line-height: 1.6;
    font-family: var(--font-serif);
    font-size: 1.05rem;
  }
  .project-body .announcement {
    font-family: var(--font-soft);
    font-weight: 600;
    color: var(--teal);
    background: var(--peach-soft);
    padding: 0.5rem 0.85rem;
    border-radius: 8px;
    display: inline-block;
    font-size: 0.92rem;
    margin-bottom: 1rem;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0.5rem 0 1rem;
  }
  .tag {
    font-family: var(--font-soft);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.3rem 0.7rem;
    border-radius: 100px;
    background: var(--bg-card);
    border: 1px solid var(--rule);
    color: var(--ink-soft);
    font-weight: 500;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .tag:hover {
    border-color: var(--teal);
    color: var(--teal);
  }
  .links {
    display: flex;
    gap: 1.4rem;
    flex-wrap: wrap;
  }
  .links a {
    color: var(--teal);
    text-decoration: none;
    border-bottom: 1px solid var(--teal-soft);
    font-weight: 500;
    font-size: 0.95rem;
    transition: color 0.2s ease;
  }
  .links a:hover {
    color: var(--peach);
  }
  .no-results {
    font-family: var(--font-soft);
    color: var(--ink-soft);
    text-align: center;
    padding: 4rem 0;
    font-size: 1rem;
  }
  @media (max-width: 720px) {
    .project {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }
</style>
