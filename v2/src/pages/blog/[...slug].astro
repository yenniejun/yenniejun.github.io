---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.data.path.replace(/^\/blog\//, '').replace(/\/$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const dateStr = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
});
---
<Layout title={`${post.data.title} — Yennie Jun`}>
  <Header current="/writing" />
  <main>
    <article class="post fade-up">
      <header class="post-header">
        <p class="meta">
          {dateStr}
          {post.data.tags && post.data.tags.length > 0 && (
            <span> · {post.data.tags.join(' · ')}</span>
          )}
        </p>
        <h1>{post.data.title}</h1>
        {post.data.description && <p class="lede">{post.data.description}</p>}
      </header>
      <div class="content">
        <Content />
      </div>

      <p class="back"><a href="/writing">← back to writing</a></p>
    </article>

    <Footer />
  </main>
</Layout>

<style>
  .post {
    max-width: 680px;
    margin: 2rem auto 0;
  }
  .post-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--rule);
  }
  .post-header .meta {
    font-family: var(--font-soft);
    font-size: 0.78rem;
    color: var(--ink-soft);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin: 0 0 1rem;
    font-weight: 500;
  }
  .post-header h1 {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 2.8rem;
    line-height: 1.1;
    margin: 0 0 1rem;
    letter-spacing: -0.03em;
    color: var(--ink);
  }
  .post-header .lede {
    font-family: var(--font-soft);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--ink-soft);
    margin: 0;
    line-height: 1.5;
  }
  .content {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    line-height: 1.75;
    color: var(--ink);
  }
  .content :global(p) {
    margin: 0 0 1.4rem;
  }
  .content :global(h2) {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 1.8rem;
    margin: 3rem 0 1rem;
    letter-spacing: -0.02em;
  }
  .content :global(h3) {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: 1.4rem;
    margin: 2.5rem 0 0.8rem;
    letter-spacing: -0.01em;
  }
  .content :global(blockquote) {
    border-left: 3px solid var(--peach);
    padding: 0.5rem 1.5rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--ink-soft);
  }
  .content :global(a) {
    color: var(--teal);
    border-bottom: 1px solid var(--teal-soft);
    text-decoration: none;
    font-weight: 500;
  }
  .content :global(a:hover) {
    color: var(--peach);
  }
  .content :global(img) {
    max-width: 100%;
    height: auto;
    margin: 2rem 0;
    border-radius: 10px;
    display: block;
  }
  .content :global(code) {
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    background: var(--peach-soft);
    padding: 0.12em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
  }
  .content :global(pre) {
    background: #f4f0ea;
    padding: 1.2rem;
    border-radius: 10px;
    overflow-x: auto;
    margin: 1.5rem 0;
  }
  .content :global(pre code) {
    background: none;
    padding: 0;
  }
  .content :global(ul), .content :global(ol) {
    margin: 0 0 1.4rem 1.5rem;
    padding: 0;
  }
  .content :global(li) {
    margin-bottom: 0.5rem;
  }
  .back {
    margin: 5rem 0 0;
    font-family: var(--font-soft);
    font-size: 0.95rem;
  }
  .back a {
    color: var(--teal);
    text-decoration: none;
    border-bottom: 1px solid var(--teal-soft);
  }
</style>
