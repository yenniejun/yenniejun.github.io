---
const { title, icon } = Astro.props;
---
<header class="page-header fade-up">
  <h1>
    <span>{title}</span>
    {icon && <img src={`/icons/page-${icon}.svg`} alt="" class="page-icon" width="42" height="42" />}
  </h1>
  <div class="page-header-desc"><slot /></div>
</header>

<style>
  .page-header {
    margin: 3rem 0 4rem;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 2.5rem;
  }
  .page-header h1 {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 3.5rem;
    line-height: 1.05;
    margin: 0 0 1rem;
    letter-spacing: -0.03em;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .page-icon {
    width: 2.6rem;
    height: 2.6rem;
    display: inline-block;
    transition: transform 0.5s ease;
    animation: page-icon-sway 6s ease-in-out infinite;
    transform-origin: 50% 75%;
  }
  @keyframes page-icon-sway {
    0%, 100% { transform: rotate(-4deg); }
    50%      { transform: rotate(4deg); }
  }
  .page-header-desc {
    font-family: var(--font-soft);
    font-size: 1.1rem;
    color: var(--ink-soft);
    max-width: 36rem;
  }
  .page-header-desc :global(a) {
    color: var(--teal);
    text-decoration: none;
    border-bottom: 1px solid var(--teal-soft);
  }
  .page-header-desc :global(p) {
    margin: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    .page-icon { animation: none; }
  }
  @media (max-width: 720px) {
    .page-header h1 { font-size: 2.5rem; gap: 0.7rem; }
    .page-icon { width: 2rem; height: 2rem; }
    .page-header { margin: 1.5rem 0 3rem; padding-bottom: 1.5rem; }
  }
</style>
