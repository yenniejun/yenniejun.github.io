---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/PageHeader.astro';
import BookListItem from '../components/BookListItem.astro';

const books = (await getCollection('books'))
  .filter(b => b.data.date)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags: string[] = [...new Set(books.flatMap(b => b.data.tags || []))];

// Sort tags by frequency (most common first)
const sortedTags = allTags
  .map(tag => ({
    tag,
    count: books.filter(b => b.data.tags?.includes(tag)).length
  }))
  .sort((a, b) => b.count - a.count)
  .map(item => item.tag);
---
<Layout title="Bookshelf — Yennie Jun">
  <Header current="/books" />
  <main>
    <PageHeader title="My Bookshelf" icon="books">
      <p>Notes and thoughts on some of my recent favorite reads.</p>
    </PageHeader>

    <div class="filter-bar fade-up" id="filter-bar">
      <button class="filter-pill active" data-filter="all">
        All <span class="count">{books.length}</span>
      </button>
      {sortedTags.map(tag => {
        const count = books.filter(b => b.data.tags?.includes(tag)).length;
        return (
          <button class="filter-pill" data-filter={tag}>
            {tag} <span class="count">{count}</span>
          </button>
        );
      })}
    </div>

    <div class="books">
      {books.map(book => <BookListItem book={book} />)}
      <p class="no-results" id="no-results" hidden>No books with that tag.</p>
    </div>

    <Footer />
  </main>
</Layout>

<script is:inline>
  (function () {
    const pills = document.querySelectorAll('.filter-pill');
    const items = document.querySelectorAll('.book-item');
    const noResults = document.getElementById('no-results');

    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        const filter = pill.dataset.filter;
        pills.forEach((p) => p.classList.toggle('active', p === pill));

        let visibleCount = 0;
        items.forEach((item) => {
          const tags = JSON.parse(item.dataset.tags || '[]');
          const matches = filter === 'all' || tags.includes(filter);
          if (matches) {
            item.classList.remove('hide');
            visibleCount++;
          } else {
            item.classList.add('hide');
          }
        });
        if (noResults) noResults.hidden = visibleCount > 0;
      });
    });
  })();
</script>

<style>
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0 0 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--rule);
  }
  .filter-pill {
    font-family: var(--font-soft);
    font-size: 0.85rem;
    padding: 0.4rem 0.85rem;
    border-radius: 100px;
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--ink-soft);
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    line-height: 1;
  }
  .filter-pill:hover {
    border-color: var(--teal);
    color: var(--ink);
  }
  .filter-pill.active {
    background: var(--peach-soft);
    color: var(--teal);
    border-color: var(--peach);
    font-weight: 600;
  }
  .filter-pill .count {
    font-size: 0.72rem;
    opacity: 0.65;
    font-weight: 400;
  }

  /* hide filtered-out items */
  :global(.book-item.hide) {
    display: none;
  }

  .no-results {
    font-family: var(--font-soft);
    color: var(--ink-soft);
    text-align: center;
    padding: 4rem 0;
    font-size: 1rem;
  }
</style>
